<?xml version="1.0"?>
<!--
/**
 * ETechFlow_AdvancedProductReviewsHyva — Hyvä compatibility module
 *
 * Loads after the base module and the Hyvä theme module so its layout/templates
 * win in the Hyvä theme. Hyva_Theme is a soft dependency (only present on Hyvä
 * stores); the <sequence> entry simply orders loading when it exists.
 *
 * @author ETechFlow <etechflow0@gmail.com>
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="ETechFlow_AdvancedProductReviewsHyva" setup_version="1.0.0">
        <sequence>
            <module name="ETechFlow_AdvancedProductReviews"/>
            <module name="Hyva_Theme"/>
        </sequence>
    </module>
</config>
