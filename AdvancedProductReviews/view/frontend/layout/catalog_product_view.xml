<?xml version="1.0"?>
<!--
/**
 * ETechFlow_AdvancedProductReviews — storefront product page wiring
 *
 * @author ETechFlow <etechflow0@gmail.com>
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="ETechFlow_AdvancedProductReviews::css/reviews.css"/>
    </head>
    <body>
        <!-- Override the core review form to control field order and inline the
             extra fields (pros/cons, recommend, photo/video). The ViewModel is
             passed in so the template can read config flags. -->
        <referenceBlock name="product.review.form"
                        template="ETechFlow_AdvancedProductReviews::review/form.phtml">
            <arguments>
                <argument name="etf_view_model" xsi:type="object">
                    ETechFlow\AdvancedProductReviews\ViewModel\ReviewData
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
